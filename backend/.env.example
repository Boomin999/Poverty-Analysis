NODE_ENV=production
GEMINI_API_KEY=your_gemini_api_key_here

# Railway sets PORT automatically in production.
# You usually do not need to set API_PORT when deploying there.
# API_PORT=3001

# Optional: use one of these when mounting a persistent Railway volume.
# DATABASE_DIR=/app/backend/data/database
# SQLITE_PATH=/app/backend/data/database/poverty-insights.sqlite
